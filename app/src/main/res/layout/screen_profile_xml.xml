<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/profileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xml_warm_surface"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/profileTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_2"
        android:paddingTop="@dimen/space_3"
        android:paddingEnd="@dimen/screen_horizontal"
        android:paddingBottom="@dimen/space_3">

        <ImageButton
            android:id="@+id/profileBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/ic_xml_arrow_back" />

        <TextView
            style="@style/Widget.Nimons.Xml.TitleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_2"
            android:text="Profile" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_horizontal"
            android:paddingTop="@dimen/space_4"
            android:paddingEnd="@dimen/screen_horizontal"
            android:paddingBottom="@dimen/space_6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="@dimen/profile_avatar_size"
                    android:layout_height="@dimen/profile_avatar_size">

                    <ImageView
                        android:id="@+id/profileAvatarImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_xml_avatar_circle"
                        android:clipToOutline="true"
                        android:contentDescription="Profile photo"
                        android:outlineProvider="background"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/profileAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_xml_avatar_circle"
                        android:fontFamily="@font/geist_medium"
                        android:gravity="center"
                        android:textColor="@color/xml_text_primary"
                        android:textSize="20sp" />

                    <ImageButton
                        android:id="@+id/profilePhotoEditButton"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_xml_edit_button_circle_selector"
                        android:contentDescription="Edit profile photo"
                        android:padding="7dp"
                        android:src="@drawable/ic_xml_edit"
                        android:tint="@android:color/white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_4"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Widget.Nimons.Xml.Eyebrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Name" />

                    <TextView
                        android:id="@+id/profileName"
                        style="@style/Widget.Nimons.Xml.HeadlineSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/profileEditButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Edit name"
                    android:padding="10dp"
                    android:src="@drawable/ic_xml_edit" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_4"
                android:background="@color/xml_border" />

            <TextView
                style="@style/Widget.Nimons.Xml.TitleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:text="Account details" />

            <TextView
                style="@style/Widget.Nimons.Xml.BodyMuted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:text="Core identity details used across the app." />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:orientation="vertical">

                <TextView
                    style="@style/Widget.Nimons.Xml.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student ID" />

                <TextView
                    android:id="@+id/profileStudentId"
                    style="@style/Widget.Nimons.Xml.BodyLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/xml_text_primary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_3"
                android:layout_marginBottom="@dimen/space_3"
                android:background="@color/xml_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/Widget.Nimons.Xml.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email" />

                <TextView
                    android:id="@+id/profileEmail"
                    style="@style/Widget.Nimons.Xml.BodyLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/xml_text_primary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_3"
                android:background="@color/xml_border" />

            <TextView
                style="@style/Widget.Nimons.Xml.TitleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:text="Preferences" />

            <TextView
                style="@style/Widget.Nimons.Xml.BodyMuted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:text="Control device notifications and live location privacy." />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Widget.Nimons.Xml.BodyLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifications"
                        android:textColor="@color/xml_text_primary" />

                    <TextView
                        style="@style/Widget.Nimons.Xml.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Receive family push notifications." />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/profileNotificationsSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/xml_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Widget.Nimons.Xml.BodyLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share location"
                        android:textColor="@color/xml_text_primary" />

                    <TextView
                        style="@style/Widget.Nimons.Xml.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Send your live location to family members." />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/profileLocationSharingSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/xml_border" />

            <TextView
                style="@style/Widget.Nimons.Xml.TitleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:text="Session" />

            <TextView
                style="@style/Widget.Nimons.Xml.BodyMuted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:text="Sign out when you need to switch accounts on this device." />

            <LinearLayout
                android:id="@+id/profileSignOutButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/space_4"
                android:background="@drawable/bg_xml_dark_button_selector"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_4"
                android:paddingEnd="@dimen/space_4">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_xml_sign_out" />

                <TextView
                    style="@style/Widget.Nimons.Xml.ButtonText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Sign out"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/profileProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/space_6"
        android:visibility="gone" />
</LinearLayout>
