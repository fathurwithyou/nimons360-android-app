<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/iconOptionRoot"
    android:layout_width="@dimen/family_icon_option_size"
    android:layout_height="@dimen/family_icon_option_size"
    android:layout_margin="6dp"
    android:background="@drawable/bg_xml_icon_unselected">

    <ImageView
        android:id="@+id/iconOptionImage"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:contentDescription="@null"
        android:scaleType="centerInside" />

    <TextView
        android:id="@+id/iconOptionCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="@dimen/space_2"
        android:fontFamily="@font/geist_bold"
        android:text="✓"
        android:textColor="@color/xml_text_primary"
        android:textSize="12sp"
        android:visibility="gone" />
</FrameLayout>
