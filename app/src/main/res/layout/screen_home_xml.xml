<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xml_warm_background">

    <View
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@drawable/bg_xml_marble_hero" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/homeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/homeScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/homeHeroContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/screen_horizontal"
                    android:paddingTop="@dimen/space_4"
                    android:paddingEnd="@dimen/screen_horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Widget.Nimons.Xml.TitleHero"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Family" />

                        <TextView
                            style="@style/Widget.Nimons.Xml.TitleHero"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-6dp"
                            android:text="Spaces"
                            android:textStyle="italic" />

                        <TextView
                            style="@style/Widget.Nimons.Xml.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="Curated for you: Discover and connect with family communities."
                            android:textColor="@color/xml_text_secondary" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/homeProfileButton"
                        style="@style/Widget.Nimons.Xml.TopBarIconButton"
                        android:layout_marginStart="@dimen/space_4"
                        android:contentDescription="Profile"
                        android:src="@drawable/ic_xml_account_circle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:background="@drawable/bg_xml_sheet_top_round"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/screen_horizontal"
                    android:paddingTop="@dimen/space_6"
                    android:paddingEnd="@dimen/screen_horizontal"
                    android:paddingBottom="@dimen/space_6">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Widget.Nimons.Xml.Eyebrow"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My Families" />

                            <TextView
                                android:id="@+id/homeMyFamiliesMeta"
                                style="@style/Widget.Nimons.Xml.BodySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/homeCreateFamilyButton"
                            style="@style/Widget.Nimons.Xml.ButtonText"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/button_compact_height"
                            android:background="@drawable/bg_xml_secondary_button"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_4"
                            android:paddingEnd="@dimen/space_4"
                            android:text="Create family" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/homeMyFamiliesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:id="@+id/homeMyFamiliesSkeleton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <include layout="@layout/item_skeleton_family_row" />
                        <include layout="@layout/item_skeleton_family_row" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/homeMyFamiliesEmpty"
                        style="@style/Widget.Nimons.Xml.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:background="@drawable/bg_xml_surface_muted"
                        android:padding="@dimen/space_4"
                        android:text="You have not joined any families yet."
                        android:textColor="@color/xml_text_secondary"
                        android:visibility="gone" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/space_6"
                        android:layout_marginBottom="@dimen/space_6"
                        android:background="@color/xml_border" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Widget.Nimons.Xml.Eyebrow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Discover Families" />

                        <TextView
                            android:id="@+id/homeDiscoverFamiliesMeta"
                            style="@style/Widget.Nimons.Xml.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/homeDiscoverFamiliesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:id="@+id/homeDiscoverFamiliesSkeleton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <include layout="@layout/item_skeleton_family_row" />
                        <include layout="@layout/item_skeleton_family_row" />
                        <include layout="@layout/item_skeleton_family_row" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/homeDiscoverFamiliesEmpty"
                        style="@style/Widget.Nimons.Xml.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:background="@drawable/bg_xml_surface_muted"
                        android:padding="@dimen/space_4"
                        android:text="No families available to discover right now."
                        android:textColor="@color/xml_text_secondary"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


</FrameLayout>
