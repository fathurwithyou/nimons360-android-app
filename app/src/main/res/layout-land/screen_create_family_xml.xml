<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/createFamilyRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xml_warm_surface"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/createFamilyTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_2"
        android:paddingTop="@dimen/space_3"
        android:paddingEnd="@dimen/screen_horizontal"
        android:paddingBottom="@dimen/space_3">

        <ImageButton
            android:id="@+id/createFamilyBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/ic_xml_arrow_back" />

        <TextView
            style="@style/Widget.Nimons.Xml.TitleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_2"
            android:text="Create family" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_horizontal"
            android:paddingTop="@dimen/space_5"
            android:paddingEnd="@dimen/screen_horizontal"
            android:paddingBottom="@dimen/space_6">

            <TextView
                style="@style/Widget.Nimons.Xml.HeadlineMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create a new family space" />

            <TextView
                style="@style/Widget.Nimons.Xml.BodyMuted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:text="Choose one name and one icon. The action stays predictable at the bottom." />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_xml_surface_card">

                    <ImageView
                        android:id="@+id/createFamilyPreviewIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:scaleType="centerInside" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_4"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Widget.Nimons.Xml.Eyebrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Preview" />

                    <TextView
                        android:id="@+id/createFamilyPreviewName"
                        style="@style/Widget.Nimons.Xml.TitleLarge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Your family name" />

                    <TextView
                        android:id="@+id/createFamilyPreviewHint"
                        style="@style/Widget.Nimons.Xml.BodySmall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Choose an icon to complete the family tile." />
                </LinearLayout>
            </LinearLayout>

            <EditText
                android:id="@+id/createFamilyNameInput"
                style="@style/Widget.Nimons.Xml.Field"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/space_6"
                android:background="@drawable/bg_xml_surface_muted"
                android:hint="Family name"
                android:imeOptions="actionDone"
                android:inputType="textCapWords"
                android:paddingStart="@dimen/space_4"
                android:paddingEnd="@dimen/space_4"
                android:singleLine="true" />

            <TextView
                style="@style/Widget.Nimons.Xml.TitleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_6"
                android:text="Choose icon" />

            <TextView
                style="@style/Widget.Nimons.Xml.BodySmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:text="Choose one symbol for the family tile and detail header." />

            <GridLayout
                android:id="@+id/createFamilyIconsGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_3"
                android:columnCount="4"
                android:orientation="horizontal"
                android:rowCount="2"
                android:useDefaultMargins="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/createFamilyBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/xml_warm_surface"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_horizontal"
        android:paddingTop="@dimen/space_3"
        android:paddingEnd="@dimen/screen_horizontal"
        android:paddingBottom="@dimen/space_6">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/createFamilySubmitButton"
            style="@style/Widget.Nimons.Xml.ButtonText"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_xml_dark_button_selector"
            android:text="Create family"
            android:textColor="@android:color/white" />
    </LinearLayout>
</LinearLayout>
