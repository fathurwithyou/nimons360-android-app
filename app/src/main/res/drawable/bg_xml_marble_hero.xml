<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/xml_warm_background" />
        </shape>
    </item>
    <item
        android:width="220dp"
        android:height="240dp"
        android:gravity="top|start"
        android:left="-110dp"
        android:top="-20dp">
        <shape android:shape="oval">
            <solid android:color="@color/xml_marble_one" />
        </shape>
    </item>
    <item
        android:width="140dp"
        android:height="260dp"
        android:gravity="top|center_horizontal"
        android:top="-70dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/xml_marble_two" />
            <corners android:radius="80dp" />
        </shape>
    </item>
    <item
        android:width="220dp"
        android:height="180dp"
        android:gravity="top|end"
        android:right="-64dp"
        android:top="-12dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/xml_marble_three" />
            <corners android:radius="96dp" />
        </shape>
    </item>
</layer-list>
