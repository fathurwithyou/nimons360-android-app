<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/xml_black_pressed" />
            <stroke
                android:width="1dp"
                android:color="@color/xml_black_border" />
            <size
                android:width="28dp"
                android:height="28dp" />
        </shape>
    </item>
    <item android:drawable="@drawable/bg_xml_edit_button_circle" />
</selector>